{{!< default}}

{{#post}}
<article class="post page{{#if feature_image}} has-image{{/if}}">
    {{#if @page.show_title_and_feature_image}}
        <header class="post-header">
            <h1 class="post-title">{{title}}</h1>
        </header>

        {{#if feature_image}}
            <figure class="post-feature-image">
                <img src="{{img_url feature_image size="l"}}"
                     srcset="{{img_url feature_image size="m"}} 1000w, {{img_url feature_image size="l"}} 1600w"
                     sizes="(max-width: 720px) 100vw, 720px"
                     alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
            </figure>
        {{/if}}
    {{/if}}

    <section class="post-content gh-content">
        {{content}}
    </section>
</article>
{{/post}}
