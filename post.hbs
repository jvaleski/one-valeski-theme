{{!< default}}

{{#post}}
<article class="post{{#if feature_image}} has-image{{/if}}">
    <header class="post-header">
        {{#if primary_tag}}
            <a class="post-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
        {{/if}}
        <h1 class="post-title">{{title}}</h1>
        <div class="post-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
            {{#if reading_time}}<span class="post-meta-sep">&middot;</span><span>{{reading_time}}</span>{{/if}}
            {{#primary_author}}<span class="post-meta-sep">&middot;</span><span>{{name}}</span>{{/primary_author}}
        </div>
    </header>

    {{#if feature_image}}
        <figure class="post-feature-image">
            <img src="{{img_url feature_image size="l"}}"
                 srcset="{{img_url feature_image size="m"}} 1000w, {{img_url feature_image size="l"}} 1600w"
                 sizes="(max-width: 720px) 100vw, 720px"
                 alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
            {{#if feature_image_caption}}<figcaption>{{feature_image_caption}}</figcaption>{{/if}}
        </figure>
    {{/if}}

    <section class="post-content gh-content">
        {{content}}
    </section>

    <footer class="post-footer">
        {{#if tags}}
            <div class="post-tags">
                {{#foreach tags}}<a class="post-tag" href="{{url}}">{{name}}</a>{{/foreach}}
            </div>
        {{/if}}
    </footer>
</article>

{{#if comments}}
    <section class="post-comments gh-content">
        {{comments}}
    </section>
{{/if}}
{{/post}}
